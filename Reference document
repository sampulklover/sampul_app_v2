// With commas: RM 10,000.00
String formatCurrencyWithCommas(int cents) {
  final amount = cents / 100;
  return 'RM ${amount.toStringAsFixed(2).replaceAllMapped(
    RegExp(r'(\d{1,3})(?=(\d{3})+(?!\d))'),
    (Match m) => '${m[1]},',
  )}';
}
