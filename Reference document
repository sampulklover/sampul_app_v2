## Data Models

### TrustPayment Model

```dart
class TrustPayment {
  final String id;
  final String trustId;
  final String uuid;
  final int amount; // Amount in cents
  final String status;
  final String? chipPaymentId;
  final String? chipClientId;
  final DateTime createdAt;
  final DateTime? updatedAt;

  TrustPayment({
    required this.id,
    required this.trustId,
    required this.uuid,
    required this.amount,
    required this.status,
    this.chipPaymentId,
    this.chipClientId,
    required this.createdAt,
    this.updatedAt,
  });

  factory TrustPayment.fromJson(Map<String, dynamic> json) {
    return TrustPayment(
      id: json['id'],
      trustId: json['trust_id'],
      uuid: json['uuid'],
      amount: json['amount'] as int,
      status: json['status'],
      chipPaymentId: json['chip_payment_id'],
      chipClientId: json['chip_client_id'],
      createdAt: DateTime.parse(json['created_at']),
      updatedAt: json['updated_at'] != null 
          ? DateTime.parse(json['updated_at']) 
          : null,
    );
  }

  // Helper method to format amount
  String get formattedAmount {
    final amountInRinggit = amount / 100;
    return 'RM ${amountInRinggit.toStringAsFixed(2)}';
  }

  // Helper method to check if payment is successful
  bool get isSuccessful {
    return ['paid', 'settled', 'cleared'].contains(status);
  }
}
```

### Trust Model (with payments)

```dart
class Trust {
  final String id;
  final String uuid;
  final String trustCode;
  final List<TrustPayment>? trustPayments;
  final TrustPaymentConfig? trustPayment;
  // ... other trust fields

  Trust({
    required this.id,
    required this.uuid,
    required this.trustCode,
    this.trustPayments,
    this.trustPayment,
  });

  // Calculate total paid
  int get totalPaidInCents {
    if (trustPayments == null) return 0;
    return trustPayments!
        .where((p) => p.isSuccessful)
        .fold(0, (sum, payment) => sum + payment.amount);
  }

  // Calculate remaining amount
  int get remainingInCents {
    return MIN_TRUST_AMOUNT - totalPaidInCents;
  }

  // Calculate progress percentage
  double get progressPercentage {
    return (totalPaidInCents / MIN_TRUST_AMOUNT) * 100;
  }
}
```

